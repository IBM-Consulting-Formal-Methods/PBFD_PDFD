stateDiagram-v2
    direction LR

    [*] --> S0

    state "Idle" as S0
    state "Unit<br/>Loaded" as S1
    state "Hierarchy<br/>Resolved" as S2
    state "Children<br/>Evaluated" as S3
    state "Changes<br/>Committed" as S5
    state "Workflow<br/>Finalized" as S6

    S0 --> S1 : Load Unit
    S1 --> S2 : Resolve Hierarchy
    S2 --> S3 : Evaluate Children
    S3 --> S5 : Update / Skip Update
    S5 --> S0 : Next Unit
    S5 --> S6 : Finalize
    S6 --> S0

