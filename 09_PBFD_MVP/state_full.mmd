stateDiagram-v2
    direction TB

    %% =========================
    %% Initialization
    %% =========================
    [*] --> S0 : PBFD1 - process ContinentGrandparent level

    state S0["S0 - ContinentGrandparent processing (Level 1)"]
    S0 --> S1 : PBFD2 - process ContinentParent level

    %% =========================
    %% Parent Level
    %% =========================
    state S1["S1 - ContinentParent processing (Level 2)"]
    S1 --> S2 : PBFD3 - process Continent level

    %% =========================
    %% Continent Level
    %% =========================
    state S2["S2 - Continent processing (Level 3)"]

    S2 --> S3 : PBFD4 - process Country level
    S3 --> S4 : PBFD5 - process State level

    S2 --> S5 : PBFD6 - trigger refinement (Continent failure)
    S2 --> S_ERROR : PBFD13 - validation failure

    %% =========================
    %% State Level
    %% =========================
    state S4["S4 - State processing (Level 5)"]
    S4 --> S6 : PBFD10 - enter completion phase

    %% =========================
    %% Refinement Composite State S5
    %% =========================
    state S5 {

        [*] --> S1_ref

        state S1_ref["S1_ref(j,3) - PBFD7 refinement processing"]
        state S2_ref["S2_ref(j,3) - PBFD8 refinement validation"]
        state S3_rdep["S3_rdep(j,3) - PBFD9 refinement resolution"]

        S1_ref --> S2_ref : PBFD7 - start refinement validation
        S2_ref --> S3_rdep : PBFD8 - refinement validated
    }

    %% Refinement closure
    S5 --> S2 : PBFD9 - resume Continent processing
    S5 --> S_ERROR : PBFD14 - refinement exhausted

    %% =========================
    %% Completion Phase
    %% =========================
    state S6["S6 - Top-Down Completion (Levels 1–5)"]

    S6 --> S6 : PBFD11 - finalize next level
    S6 --> T : PBFD12 - successful termination
    S6 --> S_ERROR : PBFD15 - completion failure

    %% =========================
    %% Terminal States
    %% =========================
    state T["Success - all nodes finalized (∀n∈V: P(n)=2)"]
    state S_ERROR["Failure Termination"]

    T --> [*]
    S_ERROR --> [*]
